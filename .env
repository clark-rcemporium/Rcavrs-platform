# AVRS Platform - Development Environment

# Server
NODE_ENV=development
PORT=3000

# Database (SQLite for local development - no external dependencies)
DATABASE_URL=sqlite:///avrs.db
DATABASE_POOL_MAX=20

# CORS
CORS_ORIGIN=*

# JWT
JWT_SECRET=your-secret-key-change-in-production

# Logging
LOG_LEVEL=info

# Features
ENABLE_AUTONOMOUS_OPS=true
ENABLE_ANALYTICS=true
ENABLE_REPLICATION=true
